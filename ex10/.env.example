# ex10 RAG 튜닝 — 환경 변수 템플릿
# 사용 방법: cp .env.example .env 후 값을 채우십시오.

# ============================================================
# LLM 설정 (ollama 또는 openai 중 하나 선택)
# ============================================================

LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# OpenAI 설정 (OpenAI 사용 시, Vision과 Tool Calling 모두 gpt-4o-mini 지원)
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4o-mini

# ============================================================
# Vision LLM 설정 (§10.3, §10.4 하이브리드 파서에서 사용)
# ============================================================

# 기본 권장: qwen2.5vl:7b (RAM 8~16GB 노트북, 한국어 품질 좋음)
# 빠른 대안: minicpm-v:latest (환각 있음) / 고품질: llama3.2-vision:11b
VISION_PROVIDER=ollama
VISION_MODEL=qwen2.5vl:7b

# OpenAI Vision 사용 시 (gpt-4o-mini도 Vision 지원)
# VISION_PROVIDER=openai
OPENAI_VISION_MODEL=gpt-4o-mini

# Vision LLM 요청 타임아웃 (초)
VISION_TIMEOUT=600

# ============================================================
# 임베딩 모델 설정
# ============================================================

EMBEDDING_MODEL=jhgan/ko-sroberta-multitask

# ============================================================
# ChromaDB 설정
# ============================================================

CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=metacoding_documents

# ============================================================
# 하이브리드 파서 설정
# ============================================================

# pypdf가 빈 문자열을 돌려줄 때 Vision으로 폴백. 별도 임계값 없음.
# 렌더링 DPI (Vision LLM에 넘길 이미지 해상도. 100~150 권장)
# CLI 옵션으로도 변경 가능: --dpi 100

# ============================================================
# PostgreSQL 설정 (이전 챕터의 정형 데이터 재사용)
# ============================================================

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=rag_db
POSTGRES_USER=rag_user
POSTGRES_PASSWORD=rag_password
