# ex11 커넥트HR 에이전트 완성 — 환경 변수 템플릿
# 사용 방법: cp .env.example .env 후 값을 채우십시오.

# ============================================================
# LLM 설정 — 에이전트·Tool Calling
# (ollama 또는 openai 중 하나 선택)
# ============================================================

# LLM 공급자: "ollama" (로컬, 기본값) 또는 "openai"
LLM_PROVIDER=ollama

# Ollama 설정 (로컬 LLM 사용 시)
# Tool Calling을 지원하는 모델이어야 합니다.
# llama3.1:8b 권장. deepseek-r1:8b는 Tool Calling 미지원.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# OpenAI 설정 (OpenAI 사용 시 — Tool Calling·Vision 모두 지원)
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4o-mini

# ============================================================
# Vision LLM 설정 — 스캔 PDF 하이브리드 파서 (챕터 10)
# ============================================================

VISION_PROVIDER=ollama

# 기본 권장: qwen2.5vl:7b (RAM 8~16GB 노트북, 한국어 품질 좋음)
# 빠른 대안: minicpm-v:latest (환각 있음) / 고품질: llama3.2-vision:11b
VISION_MODEL=qwen2.5vl:7b

# OpenAI Vision 사용 시 (gpt-4o-mini도 Vision 지원)
# VISION_PROVIDER=openai
OPENAI_VISION_MODEL=gpt-4o-mini

# Vision 요청 타임아웃 (초)
VISION_TIMEOUT=600

# ============================================================
# PostgreSQL 설정 (정형 도구용)
# ============================================================

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=rag_db
POSTGRES_USER=rag_user
POSTGRES_PASSWORD=rag_password

# ============================================================
# ChromaDB 설정 (자식 청크 저장소)
# 없으면 최초 실행 시 data/docs/에서 자동 인덱싱
# ============================================================

CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=connecthr_children

# ============================================================
# 임베딩 모델 설정
# ============================================================
EMBEDDING_MODEL=jhgan/ko-sroberta-multitask

# ============================================================
# 리랭커 (챕터 8 원본 · Cross-Encoder)
# ============================================================
# BAAI/bge-reranker-v2-m3 권장. 첫 실행 시 다운로드됩니다.
CROSS_ENCODER_MODEL=BAAI/bge-reranker-v2-m3

# ============================================================
# 서버 설정
# ============================================================
# 8000이 이미 점유된 경우 다른 포트로 변경
PORT=8000
# 개발 중엔 1 (파일 변경 감지 재시작), 안정 운영은 0
UVICORN_RELOAD=1

# ============================================================
# 응답·임베딩 캐시 (챕터 7 승계)
# ============================================================
CACHE_TTL=3600
CACHE_MAX_SIZE=1000
EMBEDDING_CACHE_DIR=./outputs/embedding_cache

# ============================================================
# 로깅
# ============================================================
LOG_LEVEL=INFO
USE_JSON_LOG=false
LOG_FILE=

# ============================================================
# Langfuse 모니터링 (선택)
# ============================================================
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com
